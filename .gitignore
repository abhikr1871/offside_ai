# Root-level gitignore for Offside_AI project

# Environment Variables
.env
.env.local
.env.*.local
*.env

# OS Files
.DS_Store
.DS_Store?
._*
.Spotlight-V100
.Trashes
ehthumbs.db
Thumbs.db

# IDE and Editor
.vscode
.idea
*.swp
*.swo
*~
.vim
.emacs
*.sublime-project
*.sublime-workspace
.project
.classpath
*.c9/
*.iml
*.iws
*.ipr

# Build and Dependencies
node_modules
dist
build
.next
*.egg-info
__pycache__
*.pyc
*.pyo
*.pyd
.Python
env/
venv/
ENV/
.venv

# Logs
logs
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*
lerna-debug.log*

# Testing
coverage
.nyc_output
.pytest_cache
htmlcov

# Runtime
*.pid
*.seed
*.out
.rpt2_cache
.rts2_cache_cjs
.rts2_cache_esm
.rts2_cache_umd

# Package locks (optional, but good for monorepos)
package-lock.json
yarn.lock
pnpm-lock.yaml

# Temporary files
tmp/
temp/
*.tmp

# OS-specific git directory
.git/info/exclude

# Session files
.copilot/
scratch/
