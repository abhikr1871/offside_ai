{
  "$jsonSchema": {
    "bsonType": "object",
    "required": ["fanId", "location", "budget", "ticketId", "preferences"],
    "properties": {
      "fanId": {
        "bsonType": "string",
        "pattern": "^fan_[a-zA-Z0-9_-]+$",
        "description": "Unique identifier for the fan profile, prefixed with fan_"
      },
      "name": {
        "bsonType": "string",
        "description": "Full name of the fan"
      },
      "location": {
        "bsonType": "object",
        "required": ["city", "coordinates"],
        "properties": {
          "city": {
            "bsonType": "string",
            "description": "City name of the current location"
          },
          "coordinates": {
            "bsonType": "object",
            "required": ["latitude", "longitude"],
            "properties": {
              "latitude": {
                "bsonType": "double",
                "minimum": -90.0,
                "maximum": 90.0,
                "description": "Latitude of current location"
              },
              "longitude": {
                "bsonType": "double",
                "minimum": -180.0,
                "maximum": 180.0,
                "description": "Longitude of current location"
              }
            }
          }
        }
      },
      "budget": {
        "bsonType": "int",
        "minimum": 0,
        "description": "The maximum budget in USD allocated for match-day travel"
      },
      "ticketId": {
        "bsonType": "string",
        "pattern": "^ticket_[a-zA-Z0-9_-]+$",
        "description": "Reference ticket ID for the match, prefixed with ticket_"
      },
      "venueId": {
        "bsonType": "string",
        "pattern": "^venue_[a-zA-Z0-9_-]+$",
        "description": "Target stadium venue ID"
      },
      "preferences": {
        "bsonType": "object",
        "required": ["preferredModes", "accessibilityNeeds"],
        "properties": {
          "preferredModes": {
            "bsonType": "array",
            "items": {
              "bsonType": "string",
              "enum": ["train", "bus", "taxi", "walk", "subway"]
            },
            "description": "Ordered transit mode preferences"
          },
          "accessibilityNeeds": {
            "bsonType": "array",
            "items": {
              "bsonType": "string"
            },
            "description": "List of accessibility specifications, e.g. wheelchair access, guide dog, etc."
          }
        }
      }
    }
  }
}
